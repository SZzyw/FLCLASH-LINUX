func cliLogs() {
	resp := sendDaemonRequest(MethodLogs, nil)
	if resp.Code != 0 {
		fmt.Println("获取日志失败:", resp.Error)
		os.Exit(1)
	}

	logs, ok := resp.Data.([]interface{})
	if !ok {
		fmt.Println("无日志数据")
		return
	}

	for _, entry := range logs {
		e, _ := json.Marshal(entry)
		fmt.Println(string(e))
	}
}

func boolStatus(v bool) string {
	if v {
		return "运行中"
	}
	return "已停止"
}

func boolRunning(v bool) string {
	if v {
		return "运行中"
	}
	return "未运行"
}

func formatMode(mode string) string {
	switch mode {
	case "rule":
		return "规则模式"
	case "global":
		return "全局模式"
	case "direct":
		return "直连模式"
	default:
		return mode
	}
}
