package main

import (
	"encoding/json"
	"fmt"
	"net"
	"os"
	"time"
)

func dialDaemon() (net.Conn, error) {
	path := socketPath()
	conn, err := net.DialTimeout("unix", path, 3*time.Second)
	if err != nil {
		return nil, fmt.Errorf("无法连接到 daemon (已启动?): %w\n请先执行: systemctl start flclash-headless", err)
	}
	return conn, nil
}

func sendDaemonRequest(method DaemonMethod, params interface{}) DaemonResponse {
	conn, err := dialDaemon()
	if err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
	defer conn.Close()

	var paramsRaw json.RawMessage
	if params != nil {
		data, _ := json.Marshal(params)
		paramsRaw = data
	}

	req := DaemonRequest{
		Method: method,
		Params: paramsRaw,
	}

	encoder := json.NewEncoder(conn)
	if err := encoder.Encode(req); err != nil {
		fmt.Fprintf(os.Stderr, "发送请求失败: %v\n", err)
		os.Exit(1)
	}

	var resp DaemonResponse
	decoder := json.NewDecoder(conn)
	if err := decoder.Decode(&resp); err != nil {
		fmt.Fprintf(os.Stderr, "读取响应失败: %v\n", err)
		os.Exit(1)
	}

	return resp
}

func cliStatus() {
	resp := sendDaemonRequest(MethodStatus, nil)
	if resp.Code != 0 {
		fmt.Println("状态获取失败:", resp.Error)
		os.Exit(1)
	}

	data, _ := json.MarshalIndent(resp.Data, "", "  ")
	var status StatusData
	json.Unmarshal(data, &status)

	fmt.Println("FlClash Headless 状态")
	fmt.Println("======================")
	fmt.Printf("  守护进程: %s\n", boolStatus(status.Running))
	fmt.Printf("  核心状态: %s\n", boolRunning(status.CoreRunning))
	if status.Uptime != "" {
		fmt.Printf("  运行时长: %s\n", status.Uptime)
	}
	fmt.Printf("  运行模式: %s\n", formatMode(status.Mode))
	fmt.Printf("  TUN: %s\n", boolStatus(status.TunEnabled))
	if status.ProfileName != "" {
		fmt.Printf("  当前配置: %s\n", status.ProfileName)
	}
	if status.GlobalNow != "" {
		fmt.Printf("  全局出口: %s\n", status.GlobalNow)
	}
	if status.TrafficUp != "" {
		fmt.Printf("  上传速度: %s\n", status.TrafficUp)
		fmt.Printf("  下载速度: %s\n", status.TrafficDown)
		fmt.Printf("  总上传: %s\n", status.TotalUp)
		fmt.Printf("  总下载: %s\n", status.TotalDown)
	}
}

