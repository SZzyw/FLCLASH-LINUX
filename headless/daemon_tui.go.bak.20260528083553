package main

import (
	"encoding/json"
	"fmt"
	"os"

	"flclash-headless/input"
	"flclash-headless/model"
	"flclash-headless/renderer"
	"flclash-headless/util"
)

type daemonTUIPage string

const (
	tuiPageDashboard   daemonTUIPage = "dashboard"
	tuiPageGroups      daemonTUIPage = "groups"
	tuiPageGroupDetail daemonTUIPage = "group_detail"
	tuiPageGlobal      daemonTUIPage = "global"
	tuiPageMode        daemonTUIPage = "mode"
	tuiPageLogs        daemonTUIPage = "logs"
	tuiPageConfig      daemonTUIPage = "config"
)

type daemonTUI struct {
	page          daemonTUIPage
	selectedGroup string
	message       string
}

func RunDaemonTUI() {
	tui := &daemonTUI{page: tuiPageDashboard}
	tui.run()
}

func (t *daemonTUI) run() {
	for {
		t.render()
		inp := input.ReadInput()
		if inp.Command == "EOF" {
			return
		}
		if t.handleInput(inp) {
			return
		}
	}
}

func (t *daemonTUI) render() {
	switch t.page {
	case tuiPageDashboard:
		t.renderDashboard()
	case tuiPageGroups:
		t.renderGroups()
	case tuiPageGroupDetail:
		t.renderGroupDetail()
	case tuiPageGlobal:
		t.renderGlobal()
	case tuiPageMode:
		t.renderMode()
	case tuiPageLogs:
		t.renderLogs()
	case tuiPageConfig:
		t.renderConfig()
	default:
		t.page = tuiPageDashboard
		t.renderDashboard()
	}
	renderer.RenderPrompt()
}

func (t *daemonTUI) handleInput(inp *input.InputResult) bool {
	switch t.page {
	case tuiPageDashboard:
		return t.handleDashboardInput(inp)
	case tuiPageGroups:
		t.handleGroupsInput(inp)
	case tuiPageGroupDetail:
		t.handleGroupDetailInput(inp)
	case tuiPageGlobal:
		t.handleGlobalInput(inp)
	case tuiPageMode:
		t.handleModeInput(inp)
	case tuiPageLogs:
		if inp.Command == "b" || inp.Command == "q" {
			t.page = tuiPageDashboard
		}
	case tuiPageConfig:
		t.handleConfigInput(inp)
	}
	return false
}

func (t *daemonTUI) handleDashboardInput(inp *input.InputResult) bool {
	switch inp.Command {
	case "q":
		return true
	case "r":
		status := t.mustStatus()
		if status.CoreRunning {
			if t.confirm("核心当前正在运行，是否立即停止? [y/N]: ", false) {
				t.callMessage(MethodStop, nil)
			}
		} else {
			if t.confirm("核心当前未运行，是否立即启动? [y/N]: ", false) {
				t.callMessage(MethodStart, nil)
			}
		}
	case "g":
		t.page = tuiPageGroups
	case "x":
		t.page = tuiPageGlobal
	case "m":
		t.page = tuiPageMode
	case "n":
		status := t.mustStatus()
		next := !status.TunEnabled
		actionText := "关闭"
		if next {
			actionText = "开启"
		}
		if t.confirm("切换 TUN 会在核心运行时重启核心，是否"+actionText+"? [y/N]: ", false) {
			t.callMessage(MethodTun, TunParams{Enable: next})
		}
	case "l":
		t.page = tuiPageLogs
	case "c", "p":
		t.page = tuiPageConfig
	}
	return false
}

func (t *daemonTUI) handleGroupsInput(inp *input.InputResult) {
	switch inp.Command {
	case "b", "q":
		t.page = tuiPageDashboard
	default:
		if !inp.IsNum || inp.Number < 1 {
			return
		}
		data := t.mustGroups()
		idx := inp.Number - 1
		if idx >= len(data.Groups) {
			t.message = "无效编号"
			return
		}
		t.selectedGroup = data.Groups[idx].Name
		t.page = tuiPageGroupDetail
	}
}

func (t *daemonTUI) handleGroupDetailInput(inp *input.InputResult) {
	switch inp.Command {
	case "b", "q":
		t.selectedGroup = ""
		t.page = tuiPageGroups
	case "d", "t":
		t.showProgress("正在测试本组延迟，请稍候...")
		t.callMessage(MethodTestGroupDelay, TestGroupDelayParams{GroupName: t.selectedGroup})
	default:
		if !inp.IsNum || inp.Number < 1 {
			return
		}
		data := t.mustGroups()
		detail := data.Details[t.selectedGroup]
		if detail == nil {
			t.message = "代理组不存在"
			t.page = tuiPageGroups
			return
		}
		idx := inp.Number - 1
		if idx >= len(detail.Nodes) {
			t.message = "无效编号"
			return
		}
		node := detail.Nodes[idx]
		t.callMessage(MethodSwitchNode, SwitchNodeParams{
			GroupName: detail.Name,
			ProxyName: node.Name,
		})
	}
}

func (t *daemonTUI) handleGlobalInput(inp *input.InputResult) {
	switch inp.Command {
	case "b", "q":
		t.page = tuiPageDashboard
	default:
		if !inp.IsNum || inp.Number < 1 {
			return
		}
		data := t.mustGroups()
		idx := inp.Number - 1
		if idx >= len(data.GlobalOptions) {
			t.message = "无效编号"
			return
		}
		t.callMessage(MethodGlobal, GlobalParams{Name: data.GlobalOptions[idx].Name})
		t.page = tuiPageDashboard
	}
}

func (t *daemonTUI) handleModeInput(inp *input.InputResult) {
	modes := map[string]string{
		"1": string(model.ModeRule),
		"2": string(model.ModeGlobal),
		"3": string(model.ModeDirect),
	}
	switch inp.Command {
	case "b", "q":
		t.page = tuiPageDashboard
	default:
		mode, ok := modes[inp.Command]
		if !ok {
			return
		}
		t.callMessage(MethodMode, ModeParams{Mode: mode})
		t.page = tuiPageDashboard
	}
}

func (t *daemonTUI) handleConfigInput(inp *input.InputResult) {
	switch inp.Command {
	case "b", "q":
		t.page = tuiPageDashboard
	case "a":
		t.promptImportURL()
	case "f":
		t.promptImportFile()
	case "u":
		t.promptUpdateSubscription()
	default:
		if !inp.IsNum || inp.Number < 1 {
			return
		}
		profiles := t.mustProfiles()
		idx := inp.Number - 1
		if idx >= len(profiles.Profiles) {
			t.message = "无效编号"
			return
		}
		t.callMessage(MethodSwitchProfile, SwitchProfileParams{ProfileID: profiles.Profiles[idx].ID})
	}
}

func (t *daemonTUI) renderDashboard() {
	status := t.mustStatus()
	groups := t.mustGroups()

	util.ClearScreen()
	renderer.RenderHeader("FlClash Headless Daemon 控制台")
	renderer.RenderInfoLine("守护进程", boolStatus(status.Running))
	renderer.RenderInfoLine("核心状态", boolRunning(status.CoreRunning))
	if status.Uptime != "" {
		renderer.RenderInfoLine("运行时长", status.Uptime)
	}
	if status.ProfileName != "" {
		renderer.RenderInfoLine("当前配置", status.ProfileName)
	}
	renderer.RenderInfoLine("当前模式", formatMode(status.Mode))
	if status.GlobalNow != "" {
		renderer.RenderInfoLine("全局出口", status.GlobalNow)
	}
	renderer.RenderInfoLine("TUN", boolStatus(status.TunEnabled))

	renderer.RenderSubHeader("代理组摘要")
	if len(groups.Groups) == 0 {
		fmt.Println("  " + util.ColorDim("暂无代理组数据；核心未运行或配置没有可切换代理组。"))
	} else {
		for i, group := range groups.Groups {
			now := group.Now
			if now == "" {
				now = "--"
			}
			fmt.Printf("  [%d] %-20s -> %s\n", i+1, util.Truncate(group.Name, 20), util.Truncate(now, 24))
		}
	}

	if status.Mode == string(model.ModeGlobal) && (status.GlobalNow == "" || status.GlobalNow == "DIRECT" || status.GlobalNow == "REJECT") {
		fmt.Println()
		fmt.Println("  " + util.ColorYellow("注意: 全局模式下 GLOBAL 未选择代理出口，请按 [x] 选择全局出口。"))
	}

	t.renderMessage()
	runLabel := "启动核心"
	if status.CoreRunning {
		runLabel = "停止核心"
	}
	renderer.RenderMenu([]renderer.MenuEntry{
		{Key: "r", Label: runLabel},
		{Key: "g", Label: "打开代理组"},
		{Key: "x", Label: "选择全局出口"},
		{Key: "m", Label: "切换运行模式"},
		{Key: "n", Label: "切换 TUN"},
		{Key: "c", Label: "运行配置设置"},
		{Key: "l", Label: "查看关键日志"},
		{Key: "q", Label: "退出 TUI"},
	})
}

func (t *daemonTUI) renderGroups() {
	data := t.mustGroups()
	util.ClearScreen()
	renderer.RenderHeader("代理组列表")
	if len(data.Groups) == 0 {
		fmt.Println()
		fmt.Println("  " + util.ColorDim("当前没有可切换的代理组。"))
	} else {
		for i, group := range data.Groups {
			now := group.Now
			if now == "" {
				now = "--"
			}
			fmt.Printf("  [%d] %-20s 当前: %s\n", i+1, util.Truncate(group.Name, 20), util.Truncate(now, 28))
		}
	}
	t.renderMessage()
	renderer.RenderMenu([]renderer.MenuEntry{
		{Key: "数字", Label: "打开代理组"},
		{Key: "b", Label: "返回主面板"},
	})
}

func (t *daemonTUI) renderGroupDetail() {
	data := t.mustGroups()
	detail := data.Details[t.selectedGroup]
	util.ClearScreen()
	renderer.RenderHeader("代理组详情")
	if detail == nil {
		fmt.Println()
		fmt.Println("  " + util.ColorDim("代理组不存在。"))
	} else {
		renderer.RenderInfoLine("代理组", detail.Name)
		renderer.RenderInfoLine("当前节点", emptyAsDash(detail.Now))
		fmt.Println()
		for i, node := range detail.Nodes {
			prefix := "  "
			if node.Now {
				prefix = util.ColorGreen("  >")
			}
			suffix := ""
			if node.Now {
				suffix = util.ColorGreen("  <- 当前")
			}
			fmt.Printf("%s[%d] %-32s %8s %s\n", prefix, i+1, util.Truncate(node.Name, 32), util.FormatDelay(node.Delay), suffix)
		}
	}
	t.renderMessage()
	renderer.RenderMenu([]renderer.MenuEntry{
		{Key: "数字", Label: "切换到节点"},
		{Key: "d", Label: "测试本组延迟"},
		{Key: "b", Label: "返回代理组列表"},
	})
}

func (t *daemonTUI) renderGlobal() {
	data := t.mustGroups()
	util.ClearScreen()
	renderer.RenderHeader("全局出口选择")
	detail := data.Details["GLOBAL"]
	if detail == nil {
		fmt.Println()
		fmt.Println("  " + util.ColorDim("无法获取 GLOBAL 组信息。"))
	} else {
		renderer.RenderInfoLine("当前全局出口", emptyAsDash(detail.Now))
		fmt.Println()
		for i, node := range data.GlobalOptions {
			display := node.Name
			for _, group := range data.Groups {
				if group.Name == node.Name && group.Now != "" {
					display = fmt.Sprintf("%s -> %s", node.Name, group.Now)
					break
				}
			}
			prefix := "  "
			if node.Now {
				prefix = util.ColorGreen("  >")
			}
			suffix := ""
			if node.Now {
				suffix = util.ColorGreen("  <- 当前")
			}
			fmt.Printf("%s[%d] %-35s %s\n", prefix, i+1, util.Truncate(display, 35), suffix)
		}
	}
	t.renderMessage()
	renderer.RenderMenu([]renderer.MenuEntry{
		{Key: "数字", Label: "选择出口"},
		{Key: "b", Label: "返回主面板"},
	})
}

func (t *daemonTUI) renderMode() {
	status := t.mustStatus()
	util.ClearScreen()
	renderer.RenderHeader("运行模式")
	renderer.RenderInfoLine("当前模式", formatMode(status.Mode))
	fmt.Println()
	fmt.Println("  [1] 规则模式")
	fmt.Println("      按配置规则分流")
	fmt.Println()
	fmt.Println("  [2] 全局模式")
	fmt.Println("      绝大多数流量走全局代理")
	fmt.Println()
	fmt.Println("  [3] 直连模式")
	fmt.Println("      不走代理")
	t.renderMessage()
	renderer.RenderMenu([]renderer.MenuEntry{
		{Key: "1-3", Label: "选择模式"},
		{Key: "b", Label: "返回主面板"},
	})
}

func (t *daemonTUI) renderLogs() {
	logs := t.mustLogs()
	util.ClearScreen()
	renderer.RenderHeader("最近关键日志")
	if len(logs) == 0 {
		fmt.Println()
		fmt.Println("  " + util.ColorDim("暂无 warning/error 关键日志。"))
	} else {
		for _, entry := range logs {
			logType := entry.Type
			if logType == "" {
				logType = "info"
			}
			fmt.Printf("  [%s] %s\n", logType, entry.Payload)
		}
	}
	renderer.RenderMenu([]renderer.MenuEntry{
		{Key: "b", Label: "返回主面板"},
	})
}

func (t *daemonTUI) renderConfig() {
	profiles := t.mustProfiles()
	util.ClearScreen()
	renderer.RenderHeader("运行配置设置")
	renderer.RenderInfoLine("当前配置", emptyAsDash(profiles.CurrentProfileName))
	renderer.RenderSubHeader("可选配置")
	if len(profiles.Profiles) == 0 {
		fmt.Println("  " + util.ColorDim("暂无可选配置。"))
	} else {
		for i, profile := range profiles.Profiles {
			prefix := "  "
			suffix := ""
			if profile.Current {
				prefix = util.ColorGreen("  >")
				suffix = util.ColorGreen("  <- 当前")
			}
			fmt.Printf("%s[%d] %-28s %-6s %s\n", prefix, i+1, util.Truncate(profile.Name, 28), profileTypeLabel(profile.Type), suffix)
		}
	}
	t.renderMessage()
	renderer.RenderMenu([]renderer.MenuEntry{
		{Key: "数字", Label: "切换到配置"},
		{Key: "a", Label: "从 URL 添加配置"},
		{Key: "f", Label: "从文件路径添加配置"},
		{Key: "u", Label: "更新当前订阅"},
		{Key: "b", Label: "返回主面板"},
	})
}

func (t *daemonTUI) promptImportURL() {
	fmt.Print("  订阅 URL: ")
	url, _ := input.ReadLine()
	if url == "" || url == "b" {
		return
	}
	fmt.Print("  可选备注名 (留空则自动生成): ")
	name, _ := input.ReadLine()
	fmt.Print("  是否在导入后立即切换? [Y/n]: ")
	autoApply := input.ReadConfirm(true)
	t.callMessage(MethodImportURL, ImportURLParams{
		URL:       url,
		Name:      name,
		AutoApply: autoApply,
	})
}

func (t *daemonTUI) promptImportFile() {
	fmt.Print("  配置文件路径: ")
	path, _ := input.ReadLine()
	if path == "" || path == "b" {
		return
	}
	fmt.Print("  可选备注名 (留空则使用文件名): ")
	name, _ := input.ReadLine()
	fmt.Print("  是否在导入后立即切换? [Y/n]: ")
	autoApply := input.ReadConfirm(true)
	t.callMessage(MethodImportFile, ImportFileParams{
		Path:      path,
		Name:      name,
		AutoApply: autoApply,
	})
}

func (t *daemonTUI) promptUpdateSubscription() {
	fmt.Print("  是否更新当前订阅? [Y/n]: ")
	if !input.ReadConfirm(true) {
		return
	}
	fmt.Print("  更新后是否立即重新应用? [Y/n]: ")
	autoApply := input.ReadConfirm(true)
	t.callMessage(MethodUpdateSub, UpdateSubscriptionParams{
		AutoApply: autoApply,
	})
}

func (t *daemonTUI) mustStatus() StatusData {
	resp := sendDaemonRequest(MethodStatus, nil)
	if resp.Code != 0 {
		fmt.Fprintln(os.Stderr, "状态获取失败:", resp.Error)
		os.Exit(1)
	}
	var status StatusData
	decodeDaemonData(resp.Data, &status)
	return status
}

func (t *daemonTUI) mustGroups() GroupsData {
	resp := sendDaemonRequest(MethodGroups, nil)
	if resp.Code != 0 {
		t.message = "获取代理组失败: " + resp.Error
		return GroupsData{Details: map[string]*model.GroupDetail{}}
	}
	var data GroupsData
	decodeDaemonData(resp.Data, &data)
	if data.Details == nil {
		data.Details = map[string]*model.GroupDetail{}
	}
	return data
}

func (t *daemonTUI) mustLogs() []model.LogEntry {
	resp := sendDaemonRequest(MethodLogs, nil)
	if resp.Code != 0 {
		t.message = "获取日志失败: " + resp.Error
		return nil
	}
	var logs []model.LogEntry
	decodeDaemonData(resp.Data, &logs)
	return logs
}

func (t *daemonTUI) mustProfiles() ProfilesData {
	resp := sendDaemonRequest(MethodProfiles, nil)
	if resp.Code != 0 {
		t.message = "获取配置列表失败: " + resp.Error
		return ProfilesData{}
	}
	var profiles ProfilesData
	decodeDaemonData(resp.Data, &profiles)
	return profiles
}

func (t *daemonTUI) callMessage(method DaemonMethod, params interface{}) {
	resp := sendDaemonRequest(method, params)
	if resp.Code != 0 {
		t.message = resp.Error
		return
	}
	if msg, ok := resp.Data.(string); ok {
		t.message = msg
		return
	}
	data, _ := json.Marshal(resp.Data)
	t.message = string(data)
}

func (t *daemonTUI) showProgress(message string) {
	fmt.Println()
	fmt.Println("  " + util.ColorYellow("消息: "+message))
}

func (t *daemonTUI) confirm(prompt string, defaultYes bool) bool {
	fmt.Print("  " + prompt)
	return input.ReadConfirm(defaultYes)
}

func (t *daemonTUI) renderMessage() {
	if t.message == "" {
		return
	}
	fmt.Println()
	fmt.Println("  " + util.ColorYellow("消息: "+t.message))
	t.message = ""
}

func decodeDaemonData(data interface{}, target interface{}) {
	raw, err := json.Marshal(data)
	if err != nil {
		return
	}
	_ = json.Unmarshal(raw, target)
}

func emptyAsDash(value string) string {
	if value == "" {
		return "--"
	}
	return value
}

func profileTypeLabel(profileType model.ProfileType) string {
	switch profileType {
	case model.ProfileTypeURL:
		return "URL"
	case model.ProfileTypeFile:
		return "文件"
	default:
		return string(profileType)
	}
}
